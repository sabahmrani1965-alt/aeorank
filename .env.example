# Reddit OAuth — required in production. Reddit blocks unauthenticated requests
# from cloud datacenter IPs (Vercel/AWS/GCP) with 403 Forbidden.
# Create a "script" type app at https://www.reddit.com/prefs/apps
# After creation:
#   - REDDIT_CLIENT_ID is the short string under your app name (next to "personal use script")
#   - REDDIT_CLIENT_SECRET is the value of the "secret" field
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Required for the live LLM section in the report.
# Sign up at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional — model used. Defaults to claude-haiku-4-5 (cheap, fast).
# ANTHROPIC_MODEL=claude-haiku-4-5

# Email — used for both contact-form leads AND the free-report email.
# Sign up at https://resend.com (free tier: 3,000 emails/mo, 100/day).
# Without these, leads are still logged but no email is sent.
RESEND_API_KEY=re_...
# Where you receive lead notifications (your inbox)
LEAD_EMAIL_TO=you@yourdomain.com
# Sender — must be a verified domain on Resend.
# For initial testing, use: AEOrank <onboarding@resend.dev>
LEAD_EMAIL_FROM=AEOrank <leads@aeorank.com>

# Optional — public site URL used in email links. Auto-detected from request
# host on Vercel, but set this explicitly for cleaner email links.
# NEXT_PUBLIC_SITE_URL=https://aeorank.com
