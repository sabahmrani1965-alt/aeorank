# Required for the live LLM section in the report.
# Sign up at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional — model used. Defaults to claude-haiku-4-5 (cheap, fast).
# ANTHROPIC_MODEL=claude-haiku-4-5

# Optional — forward contact-form leads to your email via Resend.
# Sign up at https://resend.com (free tier: 3,000 emails/mo).
# RESEND_API_KEY=re_...
# LEAD_EMAIL_TO=you@yourdomain.com
# LEAD_EMAIL_FROM=leads@aeorank.com
