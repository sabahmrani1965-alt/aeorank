# Reddit data — needed in production because Reddit's public API blocks
# datacenter IPs (Vercel/AWS/GCP) with 403 Forbidden.
#
# Pick ONE of the following paths:
#
# Path A — Reddit OAuth (free, fast, best). Requires a "script" type app at
# https://www.reddit.com/prefs/apps. Reddit currently restricts new app
# creation for many accounts, so this isn't always possible.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
#
# Path B — Apify (paid, $5/mo free credit ≈ thousands of report runs).
# Sign up at https://console.apify.com and copy your API token from
# Settings → Integrations → API tokens.
APIFY_API_TOKEN=

# Required for the live LLM section in the report.
# Sign up at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional — model used. Defaults to claude-haiku-4-5 (cheap, fast).
# ANTHROPIC_MODEL=claude-haiku-4-5

# Email — used for both contact-form leads AND the free-report email.
# Sign up at https://resend.com (free tier: 3,000 emails/mo, 100/day).
# Without these, leads are still logged but no email is sent.
RESEND_API_KEY=re_...
# Where you receive lead notifications (your inbox)
LEAD_EMAIL_TO=you@yourdomain.com
# Sender — must be a verified domain on Resend.
# For initial testing, use: AEOrank <onboarding@resend.dev>
LEAD_EMAIL_FROM=AEOrank <leads@aeorank.com>

# Optional — public site URL used in email links. Auto-detected from request
# host on Vercel, but set this explicitly for cleaner email links.
# NEXT_PUBLIC_SITE_URL=https://aeorank.com

# Stripe — powers the Trial / Growth / Boost checkout buttons. Enterprise
# stays a contact form. Get your secret key at
# https://dashboard.stripe.com/apikeys (sk_test_... for testing,
# sk_live_... for production).
#
# Plan amounts and names are defined inline in lib/stripe.js, so no Stripe
# Products need to be pre-created — Stripe will auto-create one per
# checkout. Edit lib/stripe.js to change the prices.
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret — get this AFTER creating the webhook endpoint at
# https://dashboard.stripe.com/webhooks (URL: /api/webhooks/stripe,
# event: checkout.session.completed). Stripe shows the whsec_... value
# in the endpoint's "Signing secret" reveal.
STRIPE_WEBHOOK_SECRET=whsec_...
